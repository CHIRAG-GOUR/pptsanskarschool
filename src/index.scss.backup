@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700;900&display=swap');

:root {
  --skillizee-blue: #0B66E4;
  --skillizee-yellow: #FFB300;
  --skillizee-dark: #001529;
  --text-primary: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.7);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body, html {
  width: 100%;
  height: 100%;
  font-family: 'Inter', sans-serif;
  background-color: var(--skillizee-dark);
  color: var(--text-primary);
  overflow: hidden;
}

.skillizee-theme {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: radial-gradient(circle at 15% 20%, rgba(11, 102, 228, 0.15) 0%, transparent 40%),
              radial-gradient(circle at 85% 80%, rgba(255, 179, 0, 0.1) 0%, transparent 40%);
  background-color: var(--skillizee-dark);
  z-index: 1;
}


h1.title-main {
  font-family: 'Outfit', sans-serif;
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 1rem;
}

h2.subtitle {
  font-size: clamp(1.2rem, 3vw, 2rem);
  font-weight: 400;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.gradient-text-skillizee {
  background: linear-gradient(90deg, #3a86ff, #0B66E4);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.slider-viewport {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

.slider-track {
  display: flex;
  height: 100vh;
  width: max-content;
}

.slide-panel {
  width: 100vw;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 8rem 2rem 4rem; 
}

.skillizee-primary-btn {
  padding: 1rem 2rem; 
  background: var(--skillizee-blue); 
  border: none; 
  color: #fff; 
  border-radius: 20px; 
  cursor: pointer; 
  font-size: 1.5rem; 
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0px 8px 20px rgba(11, 102, 228, 0.3);
}

.skillizee-primary-btn:hover {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0px 12px 25px rgba(11, 102, 228, 0.5);
  background: #1c75f2;
}

.nav-controls {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 2rem;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(15px);
  padding: 0.5rem 1.5rem;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.1);
  z-index: 100;
}

.nav-btn {
  background: transparent;
  border: none;
  color: white;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.5rem;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.nav-btn:hover:not(.disabled) {
  background: rgba(255,255,255,0.1);
  transform: scale(1.1);
}

.nav-btn.disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.slide-indicator {
  font-family: 'Outfit', monospace;
  font-weight: 600;
  font-size: 1.1rem;
  letter-spacing: 2px;
}

.timer {
  font-family: 'Outfit', monospace;
  font-size: clamp(3rem, 10vw, 6rem);
  font-weight: 800;
  color: var(--skillizee-yellow);
  text-shadow: 0 0 30px rgba(255, 179, 0, 0.4);
}

.grid-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
  margin-top: 2rem;
}

.info-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 1.5rem;
  padding: 2rem;
  width: 250px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.info-card h3 {
  font-size: 1.2rem;
  font-weight: 600;
}

.split-screen {
  display: flex;
  flex-direction: row;
  width: 100%;
  gap: 2rem;
  margin-top: 2rem;
}

.split-side {
  flex: 1;
  padding: 3rem;
  border-radius: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.split-side.dim {
  background: rgba(255, 255, 255, 0.02);
  color: rgba(255, 255, 255, 0.4);
  border: 1px dashed rgba(255,255,255,0.1);
}

.split-side.bright {
  background: rgba(11, 102, 228, 0.15);
  border: 1px solid var(--skillizee-blue);
  box-shadow: 0 0 40px rgba(11, 102, 228, 0.2);
}

@keyframes pulse-text {
  0% { transform: scale(1); }
  50% { transform: scale(1.02); text-shadow: 0 0 20px rgba(11,102,228,0.5); }
  100% { transform: scale(1); }
}
.pulse-text { animation: pulse-text 2s infinite; }
